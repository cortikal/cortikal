{
  "name": "cortikal",
  "version": "0.1.0",
  "private": true,
  "description": "From Prompt to Production. Visually. An open-source node-based Agentic Software Engineering platform.",
  "license": "MIT",
  "author": "Cortikal Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/cortikal/cortikal.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
