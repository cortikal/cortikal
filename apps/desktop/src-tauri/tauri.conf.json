{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Cortikal",
  "version": "0.1.0",
  "identifier": "com.cortikal.app",
  "build": {
    "frontendDist": "../../apps/web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../../apps/web && npm run dev",
    "beforeBuildCommand": "cd ../../apps/web && npm run build"
  },
  "app": {
    "title": "Cortikal — From Prompt to Production",
    "windows": [
      {
        "title": "Cortikal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
